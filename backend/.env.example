# 数据库（默认 sqlite，切换 MySQL 时设置 DB_TYPE=mysql）
DB_TYPE=sqlite
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USERNAME=rag_user
DATABASE_PASSWORD=your_password
DATABASE_NAME=rag_system

# ChromaDB 本地向量库（目录: backend/core/chroma_db）
CHROMA_COLLECTION=knowledge_base

# DeepSeek LLM 配置（OpenAI 兼容）
LLM_API_KEY=your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
DEFAULT_LLM_MODEL=deepseek-chat

# Embedding 向量（硅基流动，用于知识库检索；与 LLM Key 不同）
# 注册地址：https://cloud.siliconflow.cn/
# EMBEDDING_API_KEY=your_siliconflow_api_key_here
# EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# DEFAULT_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# JWT 配置（AUTH_SECRET_KEY 长度至少 64 位，建议: openssl rand -hex 32）
AUTH_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# 应用配置
APP_TITLE=企业级RAG问答系统
DEBUG=false
